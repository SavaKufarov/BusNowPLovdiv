@model IEnumerable<BusNow.Core.Entities.Vehicle>

@{
    ViewData["Title"] = "Превозни средства";
}

<div class="mb-4">
    <h1 class="page-title">Превозни средства</h1>
    <p class="section-subtitle">Управление на автобуси и задаване на маршрути.</p>
</div>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">Създай превозно средство</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Линия</th>
                        <th>Маршрут</th>
                        <th>Рег. номер</th>
                        <th>Тип</th>
                        <th>Активно</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.TransportLine?.LineNumber</td>
                            <td>@item.Route?.Name</td>
                            <td><strong>@item.RegistrationNumber</strong></td>
                            <td>@item.VehicleType</td>
                            <td>@(item.IsActive ? "Да" : "Не")</td>
                            <td class="d-flex gap-2 flex-wrap">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Редакция</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Детайли</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Изтрий</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>