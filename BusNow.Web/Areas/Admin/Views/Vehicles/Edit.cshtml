@model BusNow.Core.Entities.Vehicle

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Vehicle</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="TransportLineId" class="control-label"></label>
                <select asp-for="TransportLineId" class="form-control" asp-items="ViewBag.TransportLineId"></select>
                <span asp-validation-for="TransportLineId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RouteId" class="control-label"></label>
                <select asp-for="RouteId" class="form-control" asp-items="ViewBag.RouteId"></select>
                <span asp-validation-for="RouteId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CurrentStopOrderIndex" class="control-label"></label>
                <input asp-for="CurrentStopOrderIndex" class="form-control" />
                <span asp-validation-for="CurrentStopOrderIndex" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RegistrationNumber" class="control-label"></label>
                <input asp-for="RegistrationNumber" class="form-control" />
                <span asp-validation-for="RegistrationNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="VehicleType" class="control-label"></label>
                <input asp-for="VehicleType" class="form-control" />
                <span asp-validation-for="VehicleType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CurrentLatitude" class="control-label"></label>
                <input asp-for="CurrentLatitude" class="form-control" />
                <span asp-validation-for="CurrentLatitude" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CurrentLongitude" class="control-label"></label>
                <input asp-for="CurrentLongitude" class="form-control" />
                <span asp-validation-for="CurrentLongitude" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LastUpdateTime" class="control-label"></label>
                <input asp-for="LastUpdateTime" class="form-control" />
                <span asp-validation-for="LastUpdateTime" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsActive" /> @Html.DisplayNameFor(model => model.IsActive)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
