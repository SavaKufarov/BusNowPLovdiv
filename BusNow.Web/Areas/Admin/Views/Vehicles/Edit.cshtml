@model BusNow.Core.Entities.Vehicle

@{
    ViewData["Title"] = "Редакция на превозно средство";
}

<div class="mb-4">
    <h1 class="page-title">Редакция на превозно средство</h1>
    <p class="section-subtitle">Промяна на настройките на автобус и маршрут.</p>
</div>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-lg-7">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CurrentLatitude" />
                    <input type="hidden" asp-for="CurrentLongitude" />
                    <input type="hidden" asp-for="CurrentStopOrderIndex" />
                    <input type="hidden" asp-for="LastUpdateTime" />
                    <input type="hidden" asp-for="IsForwardDirection" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="TransportLineId" class="form-label">Линия</label>
                        <select asp-for="TransportLineId" class="form-select" asp-items="ViewBag.TransportLineId"></select>
                        <span asp-validation-for="TransportLineId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RouteId" class="form-label">Маршрут</label>
                        <select asp-for="RouteId" class="form-select" asp-items="ViewBag.RouteId">
                            <option value="">-- избери маршрут --</option>
                        </select>
                        <span asp-validation-for="RouteId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RegistrationNumber" class="form-label">Регистрационен номер</label>
                        <input asp-for="RegistrationNumber" class="form-control" />
                        <span asp-validation-for="RegistrationNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="VehicleType" class="form-label">Тип превозно средство</label>
                        <input asp-for="VehicleType" class="form-control" />
                        <span asp-validation-for="VehicleType" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">Активно</label>
                    </div>

                    <div class="alert alert-info">
                        При смяна на маршрута превозното средство ще бъде преместено на първата спирка на новия маршрут.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Запази</button>
                        <a asp-action="Index" class="btn btn-secondary">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}