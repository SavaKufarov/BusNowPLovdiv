@model BusNow.Core.Entities.Vehicle

@{
    ViewData["Title"] = "Детайли за превозно средство";
}

<div class="mb-4">
    <h1 class="page-title">Детайли за превозно средство</h1>
    <p class="section-subtitle">Преглед на информацията за избраното превозно средство.</p>
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Линия:</strong> @Model.TransportLine?.LineNumber</p>
        <p><strong>Маршрут:</strong> @Model.Route?.Name</p>
        <p><strong>Регистрационен номер:</strong> @Model.RegistrationNumber</p>
        <p><strong>Тип:</strong> @Model.VehicleType</p>
        <p><strong>Активно:</strong> @(Model.IsActive ? "Да" : "Не")</p>
        <p><strong>Текуща спирка (индекс):</strong> @Model.CurrentStopOrderIndex</p>
        <p><strong>Координати:</strong> @Model.CurrentLatitude, @Model.CurrentLongitude</p>

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редакция</a>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </div>
    </div>
</div>