@model IEnumerable<BusNow.Web.Areas.Admin.ViewModels.UserListItemViewModel>

@{
    ViewData["Title"] = "Потребители";
}

<div class="mb-4">
    <h1 class="page-title">Потребители</h1>
    <p class="section-subtitle">Управление на потребителските профили и роли.</p>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Име</th>
                        <th>Имейл</th>
                        <th>Потребителско име</th>
                        <th>Админ</th>
                        <th>Активен</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@(string.IsNullOrWhiteSpace(user.FullName) ? "-" : user.FullName)</td>
                            <td>@user.Email</td>
                            <td>@user.UserName</td>
                            <td>@(user.IsAdmin ? "Да" : "Не")</td>
                            <td>@(user.IsActive ? "Да" : "Не")</td>
                            <td class="d-flex gap-2 flex-wrap">
                                <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Детайли</a>
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Редакция</a>
                                <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger">Деактивирай</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>