@model BusNow.Web.Areas.Admin.ViewModels.EditUserViewModel

@{
    ViewData["Title"] = "Детайли за потребител";
}

<div class="mb-4">
    <h1 class="page-title">Детайли за потребител</h1>
    <p class="section-subtitle">Преглед на профилните данни на избрания потребител.</p>
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Име:</strong> @(string.IsNullOrWhiteSpace(Model.FullName) ? "-" : Model.FullName)</p>
        <p><strong>Имейл:</strong> @Model.Email</p>
        <p><strong>Потребителско име:</strong> @Model.UserName</p>
        <p><strong>Администратор:</strong> @(Model.IsAdmin ? "Да" : "Не")</p>
        <p><strong>Активен:</strong> @(Model.IsActive ? "Да" : "Не")</p>

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редакция</a>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </div>
    </div>
</div>