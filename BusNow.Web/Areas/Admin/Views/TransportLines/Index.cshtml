@model IEnumerable<BusNow.Core.Entities.TransportLine>

@{
    ViewData["Title"] = "Линии";
}

<div class="mb-4">
    <h1 class="page-title">Линии</h1>
    <p class="section-subtitle">Управление на транспортните линии в системата.</p>
</div>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">Създай линия</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Номер</th>
                        <th>Тип</th>
                        <th>Посока 1</th>
                        <th>Посока 2</th>
                        <th>Активна</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.LineNumber</strong></td>
                            <td>@item.Type</td>
                            <td>@item.DirectionA</td>
                            <td>@item.DirectionB</td>
                            <td>@(item.IsActive ? "Да" : "Не")</td>
                            <td class="d-flex gap-2 flex-wrap">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Редакция</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Детайли</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Изтрий</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>