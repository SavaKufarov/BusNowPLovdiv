@model BusNow.Core.Entities.TransportLine

@{
    ViewData["Title"] = "Детайли за линия";
}

<div class="mb-4">
    <h1 class="page-title">Детайли за линия</h1>
    <p class="section-subtitle">Преглед на информацията за избраната транспортна линия.</p>
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Номер на линия:</strong> @Model.LineNumber</p>
        <p><strong>Тип:</strong> @Model.Type</p>
        <p><strong>Посока 1:</strong> @Model.DirectionA</p>
        <p><strong>Посока 2:</strong> @Model.DirectionB</p>
        <p><strong>Активна:</strong> @(Model.IsActive ? "Да" : "Не")</p>

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редакция</a>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </div>
    </div>
</div>