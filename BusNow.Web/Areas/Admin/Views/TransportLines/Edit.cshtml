@model BusNow.Core.Entities.TransportLine

@{
    ViewData["Title"] = "Редакция на линия";
}

<div class="mb-4">
    <h1 class="page-title">Редакция на линия</h1>
    <p class="section-subtitle">Промяна на съществуваща транспортна линия.</p>
</div>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-lg-6">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="LineNumber" class="form-label">Номер на линия</label>
                        <input asp-for="LineNumber" class="form-control" />
                        <span asp-validation-for="LineNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Type" class="form-label">Тип</label>
                        <input asp-for="Type" class="form-control" />
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DirectionA" class="form-label">Посока 1</label>
                        <input asp-for="DirectionA" class="form-control" />
                        <span asp-validation-for="DirectionA" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DirectionB" class="form-label">Посока 2</label>
                        <input asp-for="DirectionB" class="form-control" />
                        <span asp-validation-for="DirectionB" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">Активна</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Запази</button>
                        <a asp-action="Index" class="btn btn-secondary">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}