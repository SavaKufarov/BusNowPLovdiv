@model BusNow.Core.Entities.TransportLine

@{
    ViewData["Title"] = "Delete";
}

<h1>Изтрий</h1>

<h3>Сигурни ли сте, че искате да изтриете това?</h3>
<div>
    <h4>TransportLine</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.LineNumber)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.LineNumber)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Type)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Type)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DirectionA)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DirectionA)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DirectionB)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DirectionB)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Обратно към страницата</a>
    </form>
</div>
