@model BusNow.Core.Entities.TransportLine

@{
    ViewData["Title"] = "Изтриване на линия";
}

<div class="mb-4">
    <h1 class="page-title">Изтриване на линия</h1>
    <p class="section-subtitle">Потвърждение за изтриване.</p>
</div>

<div class="card border-danger">
    <div class="card-body">
        <div class="alert alert-danger">
            Сигурен ли си, че искаш да изтриеш тази линия?
        </div>

        <p><strong>Номер на линия:</strong> @Model.LineNumber</p>
        <p><strong>Тип:</strong> @Model.Type</p>
        <p><strong>Посока 1:</strong> @Model.DirectionA</p>
        <p><strong>Посока 2:</strong> @Model.DirectionB</p>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Изтрий</button>
                <a asp-action="Index" class="btn btn-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>