@model IEnumerable<BusNow.Core.Entities.Route>

@{
    ViewData["Title"] = "Маршрути";
}

<div class="mb-4">
    <h1 class="page-title">Маршрути</h1>
    <p class="section-subtitle">Управление на маршрутите на транспортните линии.</p>
</div>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">Създай маршрут</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Линия</th>
                        <th>Име</th>
                        <th>Направление</th>
                        <th>Временен</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.TransportLine?.LineNumber</td>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.Direction</td>
                            <td>@(item.IsTemporary ? "Да" : "Не")</td>
                            <td class="d-flex gap-2 flex-wrap">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Редакция</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Детайли</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Изтрий</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>