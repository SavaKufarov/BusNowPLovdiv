@model BusNow.Core.Entities.Route

@{
    ViewData["Title"] = "Детайли за маршрут";
}

<div class="mb-4">
    <h1 class="page-title">Детайли за маршрут</h1>
    <p class="section-subtitle">Преглед на информацията за избрания маршрут.</p>
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Линия:</strong> @Model.TransportLine?.LineNumber</p>
        <p><strong>Име:</strong> @Model.Name</p>
        <p><strong>Направление:</strong> @Model.Direction</p>
        <p><strong>Временен:</strong> @(Model.IsTemporary ? "Да" : "Не")</p>
        <p><strong>GeoJSON:</strong> @(string.IsNullOrWhiteSpace(Model.GeoJson) ? "Няма" : "Попълнен")</p>

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редакция</a>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </div>
    </div>
</div>