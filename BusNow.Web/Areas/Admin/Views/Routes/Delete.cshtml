@model BusNow.Core.Entities.Route

@{
    ViewData["Title"] = "Изтриване на маршрут";
}

<div class="mb-4">
    <h1 class="page-title">Изтриване на маршрут</h1>
    <p class="section-subtitle">Потвърждение за изтриване.</p>
</div>

<div class="card border-danger">
    <div class="card-body">
        <div class="alert alert-danger">
            Сигурен ли си, че искаш да изтриеш този маршрут?
        </div>

        <p><strong>Линия:</strong> @Model.TransportLine?.LineNumber</p>
        <p><strong>Име:</strong> @Model.Name</p>
        <p><strong>Направление:</strong> @Model.Direction</p>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Изтрий</button>
                <a asp-action="Index" class="btn btn-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>