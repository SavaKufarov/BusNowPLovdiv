@model BusNow.Core.Entities.Stop

@{
    ViewData["Title"] = "Създаване на спирка";
}

<div class="mb-4">
    <h1 class="page-title">Създаване на спирка</h1>
    <p class="section-subtitle">Добавяне на нова спирка с координати от карта.</p>
</div>

<div class="card">
    <div class="card-body">
        <div class="row g-4">
            <div class="col-lg-6">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Име</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Code" class="form-label">Код</label>
                        <input asp-for="Code" class="form-control" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Latitude" class="form-label">Географска ширина</label>
                        <input asp-for="Latitude" class="form-control" id="Latitude" />
                        <span asp-validation-for="Latitude" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Longitude" class="form-label">Географска дължина</label>
                        <input asp-for="Longitude" class="form-control" id="Longitude" />
                        <span asp-validation-for="Longitude" class="text-danger"></span>
                    </div>

                    <div class="alert alert-info">
                        Натисни върху картата, за да избереш местоположение на спирката.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Създай</button>
                        <a asp-action="Index" class="btn btn-secondary">Назад</a>
                    </div>
                </form>
            </div>

            <div class="col-lg-6">
                <div id="stopMap" style="height: 450px; border-radius: 16px;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        var map = L.map('stopMap').setView([42.1354, 24.7453], 13);
        var marker = null;

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        map.on('click', function (e) {
            var lat = e.latlng.lat.toFixed(6);
            var lng = e.latlng.lng.toFixed(6);

            document.getElementById('Latitude').value = lat;
            document.getElementById('Longitude').value = lng;

            if (marker) {
                marker.setLatLng(e.latlng);
            } else {
                marker = L.marker(e.latlng).addTo(map);
            }
        });
    </script>
}