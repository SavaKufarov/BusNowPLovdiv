@model BusNow.Core.Entities.Stop

@{
    ViewData["Title"] = "Детайли за спирка";
}

<div class="mb-4">
    <h1 class="page-title">Детайли за спирка</h1>
    <p class="section-subtitle">Преглед на информацията за избраната спирка.</p>
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Име:</strong> @Model.Name</p>
        <p><strong>Код:</strong> @Model.Code</p>
        <p><strong>Географска ширина:</strong> @Model.Latitude</p>
        <p><strong>Географска дължина:</strong> @Model.Longitude</p>

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редакция</a>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </div>
    </div>
</div>