@model BusNow.Core.Entities.Schedule

@{
    ViewData["Title"] = "Детайли за разписание";
}

<div class="mb-4">
    <h1 class="page-title">Детайли за разписание</h1>
    <p class="section-subtitle">Преглед на информацията за избрания запис.</p>
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Линия:</strong> @Model.TransportLine?.LineNumber</p>
        <p><strong>Маршрут:</strong> @Model.Route?.Name</p>
        <p><strong>Час на тръгване:</strong> @Model.DepartureTime.ToString(@"hh\:mm")</p>
        <p><strong>Уикенд:</strong> @(Model.IsWeekend ? "Да" : "Не")</p>
        <p><strong>Празничен ден:</strong> @(Model.IsHoliday ? "Да" : "Не")</p>

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редакция</a>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </div>
    </div>
</div>