@model IEnumerable<BusNow.Core.Entities.Schedule>

@{
    ViewData["Title"] = "Разписания";
}

<div class="mb-4">
    <h1 class="page-title">Разписания</h1>
    <p class="section-subtitle">Управление на часовете на тръгване за линиите и маршрутите.</p>
</div>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">Създай разписание</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Линия</th>
                        <th>Маршрут</th>
                        <th>Час</th>
                        <th>Уикенд</th>
                        <th>Празничен ден</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.TransportLine?.LineNumber</strong></td>
                            <td>@(item.Route?.Name ?? "Няма")</td>
                            <td>@item.DepartureTime.ToString(@"hh\:mm")</td>
                            <td>@(item.IsWeekend ? "Да" : "Не")</td>
                            <td>@(item.IsHoliday ? "Да" : "Не")</td>
                            <td class="d-flex gap-2 flex-wrap">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Редакция</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Детайли</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Изтрий</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>