@model BusNow.Core.Entities.ServiceAlert

@{
    ViewData["Title"] = "Детайли за известие";
}

<div class="mb-4">
    <h1 class="page-title">Детайли за известие</h1>
    <p class="section-subtitle">Преглед на съдържанието и настройките на известието.</p>
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Заглавие:</strong> @Model.Title</p>
        <p><strong>Описание:</strong> @Model.Description</p>
        <p><strong>Засегната линия:</strong> @(Model.AffectedLineId?.ToString() ?? "Няма")</p>
        <p><strong>Засегнат маршрут:</strong> @(Model.AffectedRouteId?.ToString() ?? "Няма")</p>
        <p><strong>Начало:</strong> @Model.StartDate.ToString("dd.MM.yyyy HH:mm")</p>
        <p><strong>Край:</strong> @Model.EndDate.ToString("dd.MM.yyyy HH:mm")</p>
        <p><strong>Активно:</strong> @(Model.IsActive ? "Да" : "Не")</p>

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редакция</a>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </div>
    </div>
</div>