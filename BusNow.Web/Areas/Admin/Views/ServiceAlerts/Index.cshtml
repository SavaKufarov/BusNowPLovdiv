@model IEnumerable<BusNow.Core.Entities.ServiceAlert>

@{
    ViewData["Title"] = "Известия";
}

<div class="mb-4">
    <h1 class="page-title">Известия</h1>
    <p class="section-subtitle">Управление на активни съобщения за потребителите.</p>
</div>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">Създай известие</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Заглавие</th>
                        <th>Начало</th>
                        <th>Край</th>
                        <th>Активно</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Title</strong></td>
                            <td>@item.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@item.EndDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(item.IsActive ? "Да" : "Не")</td>
                            <td class="d-flex gap-2 flex-wrap">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Редакция</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Детайли</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Изтрий</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>