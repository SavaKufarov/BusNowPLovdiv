@model BusNow.Core.Entities.ServiceAlert

@{
    ViewData["Title"] = "Изтриване на известие";
}

<div class="mb-4">
    <h1 class="page-title">Изтриване на известие</h1>
    <p class="section-subtitle">Потвърждение за изтриване.</p>
</div>

<div class="card border-danger">
    <div class="card-body">
        <div class="alert alert-danger">
            Сигурен ли си, че искаш да изтриеш това известие?
        </div>

        <p><strong>Заглавие:</strong> @Model.Title</p>
        <p><strong>Начало:</strong> @Model.StartDate.ToString("dd.MM.yyyy HH:mm")</p>
        <p><strong>Край:</strong> @Model.EndDate.ToString("dd.MM.yyyy HH:mm")</p>
        <p><strong>Активно:</strong> @(Model.IsActive ? "Да" : "Не")</p>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Изтрий</button>
                <a asp-action="Index" class="btn btn-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>