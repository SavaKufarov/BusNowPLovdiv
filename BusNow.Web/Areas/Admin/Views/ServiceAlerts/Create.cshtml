@model BusNow.Core.Entities.ServiceAlert

@{
    ViewData["Title"] = "Създаване на известие";
}

<div class="mb-4">
    <h1 class="page-title">Създаване на известие</h1>
    <p class="section-subtitle">Публикуване на ново съобщение към потребителите.</p>
</div>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-lg-7">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Заглавие</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Описание</label>
                        <textarea asp-for="Description" class="form-control"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AffectedLineId" class="form-label">Засегната линия</label>
                        <select asp-for="AffectedLineId" class="form-select" asp-items="ViewBag.AffectedLineId">
                            <option value="">-- няма --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AffectedRouteId" class="form-label">Засегнат маршрут</label>
                        <select asp-for="AffectedRouteId" class="form-select" asp-items="ViewBag.AffectedRouteId">
                            <option value="">-- няма --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="StartDate" class="form-label">Начало</label>
                        <input asp-for="StartDate" type="datetime-local" class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EndDate" class="form-label">Край</label>
                        <input asp-for="EndDate" type="datetime-local" class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">Активно</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Създай</button>
                        <a asp-action="Index" class="btn btn-secondary">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}