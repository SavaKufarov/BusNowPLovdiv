@model BusNow.Core.Entities.RouteStop

@{
    ViewData["Title"] = "Детайли за спирка по маршрут";
}

<div class="mb-4">
    <h1 class="page-title">Детайли за спирка по маршрут</h1>
    <p class="section-subtitle">Преглед на връзката между маршрут и спирка.</p>
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Линия:</strong> @Model.Route?.TransportLine?.LineNumber</p>
        <p><strong>Маршрут:</strong> @Model.Route?.Name</p>
        <p><strong>Спирка:</strong> @Model.Stop?.Name</p>
        <p><strong>Поредност:</strong> @Model.OrderIndex</p>
        <p><strong>Разстояние от началото:</strong> @Model.DistanceFromStartKm км</p>

        <div class="d-flex gap-2 mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Редакция</a>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </div>
    </div>
</div>