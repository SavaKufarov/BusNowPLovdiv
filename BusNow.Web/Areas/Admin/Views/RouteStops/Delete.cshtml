@model BusNow.Core.Entities.RouteStop

@{
    ViewData["Title"] = "Изтриване на спирка по маршрут";
}

<div class="mb-4">
    <h1 class="page-title">Изтриване на спирка по маршрут</h1>
    <p class="section-subtitle">Потвърждение за изтриване.</p>
</div>

<div class="card border-danger">
    <div class="card-body">
        <div class="alert alert-danger">
            Сигурен ли си, че искаш да премахнеш тази спирка от маршрута?
        </div>

        <p><strong>Маршрут:</strong> @Model.Route?.Name</p>
        <p><strong>Спирка:</strong> @Model.Stop?.Name</p>
        <p><strong>Поредност:</strong> @Model.OrderIndex</p>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Изтрий</button>
                <a asp-action="Index" class="btn btn-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>