@{
    ViewData["Title"] = "Карта";
    var focusTitle = ViewBag.FocusTitle as string;
    var isFiltered = ViewBag.IsFiltered != null && (bool)ViewBag.IsFiltered;
}

<div class="mb-4">
    <h1 class="page-title">Карта на градския транспорт</h1>
    <p class="section-subtitle">Визуализация на спирки, маршрути и превозни средства в реално време.</p>
</div>

@if (isFiltered)
{
    <div class="card mb-4 border-0">
        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h5 class="fw-bold mb-1">@focusTitle</h5>
                <p class="text-muted mb-0">Показва се филтриран изглед на картата.</p>
            </div>

            <a asp-controller="Map"
               asp-action="Index"
               class="btn btn-outline-primary">
                Обратно към всички
            </a>
        </div>
    </div>
}

<div class="card">
    <div class="card-body p-2">
        <div id="map" style="height: 700px; border-radius: 16px;"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        var map = L.map('map').setView([42.1354, 24.7453], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        var stops = @Html.Raw(ViewBag.StopsJson);
        var routes = @Html.Raw(ViewBag.RoutesJson);
        var focus = @Html.Raw(ViewBag.FocusJson ?? "null");

        var vehicleMarkers = {};
        var stopMarkers = [];
        var routeLayers = [];

        stops.forEach(function (s) {
            if (s.latitude && s.longitude) {
                var marker = L.marker([s.latitude, s.longitude])
                    .addTo(map)
                    .bindPopup(
                        "<b>" + s.name + "</b><br>Код: " + s.code +
                        "<br><a href='/Stops/Details/" + s.id + "'>Виж детайли</a>"
                    );

                stopMarkers.push({ id: s.id, marker: marker });
            }
        });

        routes.forEach(function (r) {
            if (!r.points || r.points.length < 2) return;

            var coords = r.points.map(function (p) {
                return [p.latitude, p.longitude];
            });

            var polyline = L.polyline(coords, {
                color: getColorByLine(r.lineNumber),
                weight: 5
            })
            .addTo(map)
            .bindPopup("<b>Линия " + r.lineNumber + "</b><br>" + r.name + "<br>" + r.direction);

            routeLayers.push(polyline);
        });

        if (focus) {
            if (focus.type === "stop") {
                map.setView([focus.latitude, focus.longitude], 16);

                var selectedStop = stopMarkers.find(x => x.id === focus.id);
                if (selectedStop) {
                    selectedStop.marker.openPopup();
                }
            }
            else if (focus.type === "line") {
                if (routeLayers.length > 0) {
                    var group = L.featureGroup(routeLayers);
                    map.fitBounds(group.getBounds(), { padding: [30, 30] });
                } else {
                    map.setView([focus.latitude, focus.longitude], 14);
                }
            }
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/transportHub")
            .build();

        connection.on("ReceiveVehiclePositions", function (vehicles) {
            vehicles.forEach(function (v) {
                if (!v.latitude || !v.longitude) return;

                if (vehicleMarkers[v.id]) {
                    vehicleMarkers[v.id].setLatLng([v.latitude, v.longitude]);
                    vehicleMarkers[v.id].setIcon(createBusIcon(v.lineNumber));
                    vehicleMarkers[v.id].setPopupContent(
                        "<b>Линия " + (v.lineNumber || "") + "</b><br>" +
                        "Рег. №: " + (v.registrationNumber || "") + "<br>" +
                        "Последно обновяване: " + (v.lastUpdateTime || "")
                    );
                } else {
                    vehicleMarkers[v.id] = L.marker([v.latitude, v.longitude], {
                        icon: createBusIcon(v.lineNumber)
                    })
                    .addTo(map)
                    .bindPopup(
                        "<b>Линия " + (v.lineNumber || "") + "</b><br>" +
                        "Рег. №: " + (v.registrationNumber || "") + "<br>" +
                        "Последно обновяване: " + (v.lastUpdateTime || "")
                    );
                }
            });
        });

        connection.start().catch(function (err) {
            console.error(err.toString());
        });

        function createBusIcon(lineNumber) {
            return L.divIcon({
                className: 'bus-marker-wrapper',
                html: `
                    <div class="bus-marker">
                        <div class="bus-icon">🚌</div>
                        <div class="bus-line-number">${lineNumber ?? ""}</div>
                    </div>
                `,
                iconSize: [46, 46],
                iconAnchor: [23, 23],
                popupAnchor: [0, -18]
            });
        }

        function getColorByLine(lineNumber) {
            const colorMap = {
                "1": "blue",
                "6": "red",
                "10": "green",
                "12": "orange",
                "15": "purple"
            };

            return colorMap[lineNumber] || "darkblue";
        }
    </script>
}