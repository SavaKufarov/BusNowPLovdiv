@model IEnumerable<BusNow.Core.Entities.TransportLine>

@{
    ViewData["Title"] = "Линии";
}

<div class="mb-4">
    <h1 class="page-title">Линии</h1>
    <p class="section-subtitle">Търси по номер, тип или направление.</p>
</div>

<div class="search-panel mb-4">
    <form method="get" class="row g-3">
        <div class="col-md-8">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control"
                   placeholder="Например: 1, автобус, Тракия..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Търси</button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-secondary w-100">Изчисти</a>
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h5 class="mb-2">Няма намерени линии</h5>
        <p class="mb-0">Опитай с друго търсене.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var line in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card quick-card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="fw-bold mb-0">Линия @line.LineNumber</h5>
                            <span class="badge-soft">@line.Type</span>
                        </div>

                        <p class="mb-2"><strong>Посока 1:</strong> @line.DirectionA</p>
                        <p class="mb-3"><strong>Посока 2:</strong> @line.DirectionB</p>

                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@line.Id" class="btn btn-primary">Детайли</a>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a asp-controller="Favorites" asp-action="AddLine" asp-route-lineId="@line.Id" class="btn btn-outline-primary">
                                    Любима
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}