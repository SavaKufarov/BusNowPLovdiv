@model BusNow.Core.Entities.Stop
@using BusNow.Core.Entities

@{
    ViewData["Title"] = "Детайли за спирка";
    var routeStops = ViewBag.RouteStops as List<RouteStop> ?? new List<RouteStop>();
    var predictions = ViewBag.Predictions as List<ArrivalPrediction> ?? new List<ArrivalPrediction>();
}

<div class="mb-4">
    <h1 class="page-title">@Model.Name</h1>
    <p class="section-subtitle">Информация за спирката и прогнозни пристигания.</p>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">Информация за спирката</div>
            <div class="card-body">
                <p><strong>Код:</strong> @Model.Code</p>
                <p><strong>Координати:</strong> @Model.Latitude, @Model.Longitude</p>

                <div class="d-flex gap-2 mt-3 flex-wrap">
                    <a asp-action="Index" class="btn btn-secondary">Назад</a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Favorites" asp-action="AddStop" asp-route-stopId="@Model.Id" class="btn btn-outline-primary">
                            Добави в любими
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">Прогнозни пристигания</div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle" id="etaTable">
                        <thead>
                            <tr>
                                <th>Линия</th>
                                <th>Рег. номер</th>
                                <th>Пристига след</th>
                                <th>Закъснение</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (predictions.Any())
                            {
                                @foreach (var prediction in predictions)
                                {
                                    var minutes = (int)Math.Max(0, Math.Ceiling((prediction.EstimatedArrival - DateTime.Now).TotalMinutes));
                                    <tr>
                                        <td>@prediction.Vehicle?.TransportLine?.LineNumber</td>
                                        <td>@prediction.Vehicle?.RegistrationNumber</td>
                                        <td>@minutes мин.</td>
                                        <td>@prediction.DelayMinutes мин.</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4">Няма налични прогнозни данни.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Маршрути през тази спирка</div>
            <div class="card-body">
                @if (routeStops.Any())
                {
                    <div class="row g-3">
                        @foreach (var rs in routeStops)
                        {
                            <div class="col-md-6">
                                <div class="stats-card h-100">
                                    <h6 class="fw-bold mb-1">Линия @rs.Route?.TransportLine?.LineNumber</h6>
                                    <div>@rs.Route?.Name</div>
                                    <small class="text-muted">@rs.Route?.Direction</small>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        Няма данни за маршрути през тази спирка.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const currentStopId = @Model.Id;

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/transportHub")
            .build();

        connection.on("ReceiveArrivalPredictions", function (predictions) {
            const tbody = document.querySelector("#etaTable tbody");
            const stopPredictions = predictions.filter(p => p.stopId === currentStopId);

            tbody.innerHTML = "";

            if (stopPredictions.length === 0) {
                tbody.innerHTML = `<tr><td colspan="4">Няма налични прогнозни данни.</td></tr>`;
                return;
            }

            stopPredictions.forEach(function (p) {
                tbody.innerHTML += `
                    <tr>
                        <td>${p.lineNumber ?? ""}</td>
                        <td>${p.registrationNumber ?? ""}</td>
                        <td>${p.etaMinutes} мин.</td>
                        <td>${p.delayMinutes} мин.</td>
                    </tr>
                `;
            });
        });

        connection.start().catch(function (err) {
            console.error(err.toString());
        });
    </script>
}