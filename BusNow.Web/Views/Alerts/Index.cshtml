@model IEnumerable<BusNow.Core.Entities.ServiceAlert>

@{
    ViewData["Title"] = "Известия";
}

<div class="mb-4">
    <h1 class="page-title">Известия</h1>
    <p class="section-subtitle">Актуална информация за промени, ремонти и закъснения.</p>
</div>

<div id="alertsContainer">
    @if (!Model.Any())
    {
        <div class="empty-state" id="noAlertsMessage">
            <h5 class="mb-2">Няма активни известия</h5>
            <p class="mb-0">В момента няма активни съобщения за транспорта.</p>
        </div>
    }
    else
    {
        @foreach (var alert in Model)
        {
            <div class="card mb-3 border-warning">
                <div class="card-body">
                    <h5 class="fw-bold">@alert.Title</h5>
                    <p>@alert.Description</p>
                    <p class="mb-0 text-muted">
                        <strong>Период:</strong>
                        @alert.StartDate.ToString("dd.MM.yyyy HH:mm") -
                        @alert.EndDate.ToString("dd.MM.yyyy HH:mm")
                    </p>
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/transportHub")
            .build();

        connection.on("ReceiveAlert", function (alert) {
            const container = document.getElementById("alertsContainer");
            const noAlertsMessage = document.getElementById("noAlertsMessage");

            if (noAlertsMessage) {
                noAlertsMessage.remove();
            }

            const html = `
                <div class="card mb-3 border-warning">
                    <div class="card-body">
                        <h5 class="fw-bold">${alert.title}</h5>
                        <p>${alert.description}</p>
                        <p class="mb-0 text-muted">
                            <strong>Период:</strong> ${alert.startDate} - ${alert.endDate}
                        </p>
                    </div>
                </div>
            `;

            container.insertAdjacentHTML("afterbegin", html);
        });

        connection.start().catch(function (err) {
            console.error(err.toString());
        });
    </script>
}