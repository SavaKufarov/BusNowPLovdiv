@model IEnumerable<BusNow.Core.Entities.ServiceAlert>

@{
    ViewData["Title"] = "Известия";
}

<div class="container mt-4">
    <h1 class="mb-4">Активни известия</h1>

    @if (!Model.Any())
    {
        <div class="alert alert-success">
            В момента няма активни известия.
        </div>
    }
    else
    {
        @foreach (var alert in Model)
        {
            <div class="card shadow-sm mb-3 border-warning">
                <div class="card-body">
                    <h5 class="card-title">@alert.Title</h5>
                    <p class="card-text">@alert.Description</p>
                    <p class="mb-0">
                        <strong>Период:</strong>
                        @alert.StartDate.ToString("dd.MM.yyyy HH:mm")
                        -
                        @alert.EndDate.ToString("dd.MM.yyyy HH:mm")
                    </p>
                </div>
            </div>
        }
    }
</div>