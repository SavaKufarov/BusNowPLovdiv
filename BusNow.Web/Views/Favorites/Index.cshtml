@using BusNow.Core.Entities

@{
    ViewData["Title"] = "Любими";
    var favoriteStops = ViewBag.FavoriteStops as List<FavoriteStop> ?? new List<FavoriteStop>();
    var favoriteLines = ViewBag.FavoriteLines as List<FavoriteLine> ?? new List<FavoriteLine>();
}

<div class="mb-4">
    <h1 class="page-title">Любими</h1>
    <p class="section-subtitle">Бърз достъп до любимите ти спирки и линии.</p>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Любими спирки</div>
            <div class="card-body">
                @if (favoriteStops.Any())
                {
                    <div class="row g-3">
                        @foreach (var item in favoriteStops)
                        {
                            <div class="col-12">
                                <div class="stats-card d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold">@item.Stop?.Name</div>
                                        <small class="text-muted">Код: @item.Stop?.Code</small>
                                    </div>
                                    <a asp-action="RemoveStop" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Премахни</a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        Нямаш добавени любими спирки.
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Любими линии</div>
            <div class="card-body">
                @if (favoriteLines.Any())
                {
                    <div class="row g-3">
                        @foreach (var item in favoriteLines)
                        {
                            <div class="col-12">
                                <div class="stats-card d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold">Линия @item.Line?.LineNumber</div>
                                        <small class="text-muted">@item.Line?.Type</small>
                                    </div>
                                    <a asp-action="RemoveLine" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Премахни</a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        Нямаш добавени любими линии.
                    </div>
                }
            </div>
        </div>
    </div>
</div>